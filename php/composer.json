{
    "name": "apiverve/bible",
    "description": "Bible is a simple tool for getting bible verses. Simply provide the book, chapter, and verse, and the API will return the verse.",
    "version": "1.2.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "APIVerve",
            "email": "hello@apiverve.com",
            "homepage": "https://apiverve.com"
        }
    ],
    "keywords": [
        "api",
        "apiverve",
        "bible",
        "bible",
        "bible verse",
        "bible api",
        "bible tool",
        "bible software"
    ],
    "homepage": "https://bible.apiverve.com?utm_source=php&utm_medium=homepage",
    "support": {
        "email": "hello@apiverve.com",
        "docs": "https://docs.apiverve.com/ref/bible",
        "source": "https://github.com/apiverve/bible-API/tree/main/php"
    },
    "require": {
        "php": ">=7.4",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "APIVerve\\Bible\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "APIVerve\\Bible\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
